{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/build",
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationDir": "dist/types",
    "declarationMap": false,
    "sourceMap": false,
    "module": "ESNext",
    "target": "ES2015",
    "jsx": "react-jsx",
    "noEmit": false,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@ui-range-picker/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
